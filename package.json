{
	"name": "@ryyr/worker-mailer",
	"version": "0.1.1",
	"publishConfig": {
		"access": "public"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./calendar": {
			"types": "./dist/calendar.d.ts",
			"import": "./dist/calendar.mjs",
			"require": "./dist/calendar.js"
		},
		"./testing": {
			"types": "./dist/testing.d.ts",
			"import": "./dist/testing.mjs",
			"require": "./dist/testing.js"
		},
		"./convenience": {
			"types": "./dist/convenience.d.ts",
			"import": "./dist/convenience.mjs",
			"require": "./dist/convenience.js"
		},
		"./validate": {
			"types": "./dist/validate.d.ts",
			"import": "./dist/validate.mjs",
			"require": "./dist/validate.js"
		},
		"./dkim": {
			"types": "./dist/dkim.d.ts",
			"import": "./dist/dkim.mjs",
			"require": "./dist/dkim.js"
		},
		"./batch": {
			"types": "./dist/batch.d.ts",
			"import": "./dist/batch.mjs",
			"require": "./dist/batch.js"
		},
		"./preview": {
			"types": "./dist/preview.d.ts",
			"import": "./dist/preview.mjs",
			"require": "./dist/preview.js"
		},
		"./thread": {
			"types": "./dist/thread.d.ts",
			"import": "./dist/thread.mjs",
			"require": "./dist/thread.js"
		},
		"./unsubscribe": {
			"types": "./dist/unsubscribe.d.ts",
			"import": "./dist/unsubscribe.mjs",
			"require": "./dist/unsubscribe.js"
		},
		"./html-to-text": {
			"types": "./dist/html-to-text.d.ts",
			"import": "./dist/html-to-text.mjs",
			"require": "./dist/html-to-text.js"
		},
		"./template": {
			"types": "./dist/template.d.ts",
			"import": "./dist/template.mjs",
			"require": "./dist/template.js"
		},
		"./builder": {
			"types": "./dist/builder.d.ts",
			"import": "./dist/builder.mjs",
			"require": "./dist/builder.js"
		}
	},
	"keywords": [
		"cloudflare",
		"workers",
		"cloudflare-workers",
		"email",
		"smtp"
	],
	"author": "ryyr-ry",
	"repository": {
		"type": "git",
		"url": "https://github.com/ryyr-ry/worker-mailer.git"
	},
	"license": "MIT",
	"homepage": "https://github.com/ryyr-ry/worker-mailer",
	"scripts": {
		"build": "tsup",
		"test": "vitest",
    "test:e2e": "echo 'E2E tests not yet configured. See docs/test-strategy.md' && exit 1",
		"format": "bunx biome format --write .",
		"lint": "bunx biome lint .",
		"check": "bunx biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@changesets/cli": "^2.27.9",
		"@cloudflare/vitest-pool-workers": "^0.13.0",
		"@cloudflare/workers-types": "^4.20240722.0",
		"@types/libqp": "^1.1.3",
		"@types/node": "^22.15.0",
		"letterparser": "^0.1.8",
		"libqp": "^2.1.1",
		"tsup": "^8.2.3",
		"typescript": "^5.5.2",
		"vitest": "^4.1.0",
		"wrangler": "^4.73.0"
	}
}
